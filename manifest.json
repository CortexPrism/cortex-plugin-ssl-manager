{
  "name": "cortex-plugin-ssl-manager",
  "version": "1.0.1",
  "description": "SSL/TLS Certificate Lifecycle Manager \u2014 Discover certificates, monitor expiration, test chains, auto-renew via ACME/Let's Encrypt",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-ssl-manager",
  "homepage": "https://cortexprism.io/marketplace/plugins/ssl-manager",
  "capabilities": [
    "tools",
    "network:fetch"
  ],
  "tools": [
    {
      "name": "ssl_discover",
      "description": "Discover all certificates across domains",
      "params": []
    },
    {
      "name": "ssl_monitor",
      "description": "Monitor expiration dates",
      "params": []
    },
    {
      "name": "ssl_test_chain",
      "description": "Test certificate chain",
      "params": []
    },
    {
      "name": "ssl_auto_renew",
      "description": "Auto-renew via Let's Encrypt ACME",
      "params": []
    }
  ],
  "dependencies": {},
  "peerDependencies": {
    "cortex": ">=0.51.0"
  },
  "aiDisclosure": {
    "tools": [
      "Kilo (DeepSeek) \u2014 batch scaffold"
    ],
    "humanReview": true
  }
}
